    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TPBrowser.Core\TPBrowser.Core.csproj" />
    <ProjectReference Include="..\TPBrowser.Parser\TPBrowser.Parser.csproj" />
    <ProjectReference Include="..\TPBrowser.Style\TPBrowser.Style.csproj" />
    <ProjectReference Include="..\TPBrowser.Render\TPBrowser.Render.csproj" />
  </ItemGroup>

</Project>
